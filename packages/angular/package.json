{
  "name": "@govpf/ori-angular",
  "version": "0.1.0",
  "private": false,
  "description": "Composants Angular pour Ori",
  "type": "module",
  "main": "./dist/fesm2022/Ori-angular.mjs",
  "module": "./dist/fesm2022/Ori-angular.mjs",
  "typings": "./dist/index.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
