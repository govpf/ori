    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "lucide-angular": "^0.469.0"
  },
  "devDependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@storybook/angular": "^8.6.18",
    "lucide-angular": "^0.469.0",
    "ng-packagr": "^20.3.2",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.0",
    "zone.js": "~0.15.0"
  },
  "publishConfig": {
    "access": "public"
