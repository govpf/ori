{
  "name": "ori",
  "version": "0.1.0",
  "private": true,
  "description": "Ori - design system de l'administration de la Polynésie française",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "build:tokens": "pnpm --filter @govpf/ori-tokens run build",
    "build:css": "pnpm --filter @govpf/ori-css run build",
    "build:react": "pnpm --filter @govpf/ori-react run build",
    "build:angular": "pnpm --filter @govpf/ori-angular run build",
    "storybook:react": "pnpm --filter @govpf/ori-storybook-react run storybook",
    "storybook:angular": "pnpm --filter @govpf/ori-storybook-angular run storybook",
    "build:storybook:react": "pnpm --filter @govpf/ori-storybook-react run build",
    "build:storybook:angular": "pnpm --filter @govpf/ori-storybook-angular run build",
    "demo:portail": "pnpm --filter @govpf/ori-demo-portail run dev",
    "example:landing": "pnpm --filter @govpf/ori-example-landing run dev",
    "example:keycloak": "pnpm --filter @govpf/ori-example-keycloak run dev",
    "example:agent": "pnpm --filter @govpf/ori-example-agent run dev",
    "dev:all": "pnpm --filter @govpf/ori-tools-dev-all run start",
    "dev:docker": "docker compose -f tools/dev-all/docker-compose.yml up --build",
    "dev:docker:down": "docker compose -f tools/dev-all/docker-compose.yml down",
    "dev:docker:rebuild": "docker compose -f tools/dev-all/docker-compose.yml build --no-cache",
    "clean": "rimraf --glob \"**/node_modules\" \"**/dist\" \"**/build\" \"**/.turbo\" \"**/.angular\"",
    "clean:cache": "rimraf --glob \"apps/*/node_modules/.vite\" \"apps/*/node_modules/.cache\" \"apps/*/.angular\" \"apps/*/.storybook/.cache\" \"packages/*/node_modules/.cache\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,scss}\"",
    "lint": "pnpm -r run lint",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "~5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,css,scss}": "prettier --write"
  }
}
