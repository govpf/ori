---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Toc from '../components/Toc.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface FrontmatterShape {
  title: string;
  description?: string;
  current: string;
  /**
   * Section de l'en-tête actif (Composants / Tokens / Démarrer / etc).
   * Sert à mettre en surbrillance la nav du header.
   */
  headerCurrent?: string;
}

interface Props extends Partial<FrontmatterShape> {
  /**
   * Quand utilisé via `layout:` depuis un fichier MDX, Astro passe le
   * frontmatter dans `Astro.props.frontmatter` plutôt qu'en props plates.
   */
  frontmatter?: FrontmatterShape;
  /**
   * Fourni automatiquement par Astro lorsqu'un fichier MDX utilise ce
   * layout via frontmatter `layout: ...`. Permet de générer la TOC.
   */
  headings?: Heading[];
}

// Récupérer les props depuis le frontmatter MDX OU directement (cas où
// le layout est utilisé depuis un fichier .astro).
const fm = Astro.props.frontmatter ?? (Astro.props as FrontmatterShape);
const { title, description, current, headerCurrent } = fm;
const { headings = [] } = Astro.props;
const hasToc = headings.some((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description} current={headerCurrent ?? 'components'}>
  <Sidebar current={current} />
  <article class="site-content">
    <slot />
  </article>
  {hasToc && (
    <aside class="site-toc">
      <Toc headings={headings} />
    </aside>
  )}
</BaseLayout>
