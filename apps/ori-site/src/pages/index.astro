---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Accueil"
  current="home"
  description="Ori, le design system des services administratifs de Polynésie française"
  variant="landing"
>
  <div class="site-banner">
    <div class="site-banner__inner">
    <aside class="ori-notification ori-notification--info site-banner__notice" role="status">
      <svg
        class="ori-notification__icon"
        aria-hidden="true"
        focusable="false"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10" />
        <path d="M12 16v-4" />
        <path d="M12 8h.01" />
      </svg>
      <p class="site-banner__text">
        <strong>Ori est actuellement un Proof of Concept.</strong> Les API
        peuvent évoluer sans préavis, les versions npm sont en
        <code>0.x</code>. À ne pas utiliser en production tant qu'une
        version <code>1.0</code> stable n'est pas publiée.
        <a class="ori-notification__action" href={`${base}decouvrir/pourquoi/`}>En savoir plus</a>
      </p>
    </aside>
    </div>
  </div>

  <Hero
    eyebrow="Design system des services publics PF"
    title="Une expérience numérique cohérente pour les services administratifs du Pays"
    subtitle="Ori fournit les tokens, composants et patterns nécessaires pour bâtir des portails, des espaces agents et des sites institutionnels conformes aux standards d'accessibilité et à l'identité visuelle de la Polynésie française."
  >
    <a class="ori-button ori-button--primary" href={`${base}decouvrir/pourquoi/`}>
      Démarrer avec Ori
    </a>
    <a class="ori-button ori-button--secondary" href={`${base}demo/`}>
      Voir le portail démo
    </a>
    <a class="ori-button ori-button--ghost" href="https://github.com/govpf/ori" target="_blank" rel="noreferrer">
      Voir sur GitHub
    </a>
  </Hero>

  <section class="site-section">
    <div class="site-section__inner">
      <h2 class="site-section__heading">Trois packages, trois usages</h2>
      <p class="site-section__lede">
        Selon le contexte de votre projet, vous consommerez Ori différemment.
      </p>

      <div class="ori-feature-grid">
        <article class="ori-feature-card">
          <span class="ori-feature-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </span>
          <h3 class="ori-feature-card__title">HTML statique</h3>
          <p class="ori-feature-card__description">
            Importez <code>@govpf/ori-css</code> et utilisez les classes <code>.ori-*</code>.
            Idéal pour les landing pages, emails, intégrations CMS et GLPI.
          </p>
        </article>

        <article class="ori-feature-card">
          <span class="ori-feature-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 010 8.49M7.76 16.24a6 6 0 010-8.49"/></svg>
          </span>
          <h3 class="ori-feature-card__title">React</h3>
          <p class="ori-feature-card__description">
            Importez <code>@govpf/ori-react</code> dans Next.js, Vite ou Remix
            et utilisez les composants en JSX, typés avec TypeScript.
          </p>
        </article>

        <article class="ori-feature-card">
          <span class="ori-feature-card__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9-9 9z"/></svg>
          </span>
          <h3 class="ori-feature-card__title">Angular</h3>
          <p class="ori-feature-card__description">
            Importez <code>@govpf/ori-angular</code> dans vos modules
            standalone ou classiques. Compatible Angular 20.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="site-section" style="background-color: var(--color-surface-muted);">
    <div class="site-section__inner">
      <h2 class="site-section__heading">Conçu pour le service public</h2>
      <p class="site-section__lede">
        Ori est pensé pour les contraintes des administrations PF.
      </p>

      <div class="ori-feature-grid">
        <article class="ori-feature-card">
          <h3 class="ori-feature-card__title">RGAA niveau AA</h3>
          <p class="ori-feature-card__description">
            Tous les composants sont conformes au Référentiel Général
            d'Amélioration de l'Accessibilité, niveau AA.
          </p>
        </article>

        <article class="ori-feature-card">
          <h3 class="ori-feature-card__title">Bundle minimal</h3>
          <p class="ori-feature-card__description">
            Les classes utilitaires Tailwind ne sont conservées que si elles
            sont utilisées. Les variantes inutiles sont éliminées au build.
          </p>
        </article>

        <article class="ori-feature-card">
          <h3 class="ori-feature-card__title">Cohérence cross-framework</h3>
          <p class="ori-feature-card__description">
            Une modification de design est répliquée à l'identique sur
            React et Angular. Aucun écart visuel ou comportemental.
          </p>
        </article>

        <article class="ori-feature-card">
          <h3 class="ori-feature-card__title">Mode sombre natif</h3>
          <p class="ori-feature-card__description">
            Tous les tokens disposent d'une variante <code>dark</code>.
            La bascule se fait via <code>data-theme="dark"</code>.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
