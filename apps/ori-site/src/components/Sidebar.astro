---
interface Props {
  current: string;
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<aside class="site-aside">
  <h2>Démarrer</h2>
  <ul>
    <li><a href={base} aria-current={current === 'home' ? 'page' : undefined}>Introduction</a></li>
  </ul>

  <h2>Composants</h2>
  <ul>
    <li>
      <a
        href={`${base}composants/button/`}
        aria-current={current === 'button' ? 'page' : undefined}
      >Button</a>
    </li>
  </ul>

  <h2>Fondations</h2>
  <ul>
    <li>
      <a
        href={`${base}tokens/`}
        aria-current={current === 'tokens' ? 'page' : undefined}
      >Tokens couleurs</a>
    </li>
  </ul>
</aside>
