---
interface Props {
  current: string;
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL;

interface NavSection {
  title: string;
  items: { label: string; slug: string; href: string }[];
}

const sections: NavSection[] = [
  {
    title: 'Démarrer',
    items: [
      { label: 'Introduction', slug: 'home', href: base },
      {
        label: 'Pourquoi Ori',
        slug: 'pourquoi',
        href: `${base}decouvrir/pourquoi/`,
      },
    ],
  },
  {
    title: 'Fondations',
    items: [
      { label: 'Palette', slug: 'palette', href: `${base}fondations/palette/` },
      {
        label: 'Sémantique',
        slug: 'semantique',
        href: `${base}fondations/semantique/`,
      },
      {
        label: 'Typographie',
        slug: 'typographie',
        href: `${base}fondations/typographie/`,
      },
      {
        label: 'Espacements',
        slug: 'espacements',
        href: `${base}fondations/espacements/`,
      },
      { label: 'Rayons', slug: 'rayons', href: `${base}fondations/rayons/` },
      { label: 'Ombres', slug: 'ombres', href: `${base}fondations/ombres/` },
      {
        label: 'Validation accessibilité',
        slug: 'accessibilite',
        href: `${base}fondations/accessibilite/`,
      },
    ],
  },
  {
    title: 'Composants',
    items: [
      {
        label: 'Catalogue complet',
        slug: 'components-index',
        href: `${base}composants/`,
      },
    ],
  },
  {
    title: 'Écrans Keycloak',
    items: [
      { label: 'Connexion', slug: 'login', href: `${base}keycloak/login/` },
      { label: 'Inscription', slug: 'register', href: `${base}keycloak/register/` },
      {
        label: 'Réinitialisation mot de passe',
        slug: 'reset-password',
        href: `${base}keycloak/reset-password/`,
      },
      {
        label: 'Mise à jour mot de passe',
        slug: 'update-password',
        href: `${base}keycloak/update-password/`,
      },
      { label: 'Code OTP', slug: 'otp', href: `${base}keycloak/otp/` },
      {
        label: 'Session expirée',
        slug: 'session-expired',
        href: `${base}keycloak/session-expired/`,
      },
      { label: 'Erreur', slug: 'error', href: `${base}keycloak/error/` },
    ],
  },
  {
    title: 'Intégration React',
    items: [
      {
        label: 'Installation',
        slug: 'react-installation',
        href: `${base}react/installation/`,
      },
      { label: 'Patterns', slug: 'react-patterns', href: `${base}react/patterns/` },
    ],
  },
  {
    title: 'Intégration Angular',
    items: [
      {
        label: 'Installation',
        slug: 'angular-installation',
        href: `${base}angular/installation/`,
      },
      {
        label: 'Patterns',
        slug: 'angular-patterns',
        href: `${base}angular/patterns/`,
      },
    ],
  },
  {
    title: 'Ressources',
    items: [
      { label: 'Licence', slug: 'licence', href: `${base}ressources/licence/` },
      { label: 'Contribuer', slug: 'contribuer', href: `${base}ressources/contribuer/` },
      { label: 'Code de conduite', slug: 'code-de-conduite', href: `${base}ressources/code-de-conduite/` },
      { label: 'Sécurité', slug: 'securite', href: `${base}ressources/securite/` },
    ],
  },
];
---

<aside class="ori-side-menu site-aside" aria-label="Navigation de la documentation">
  {
    sections.map((section) => (
      <div class="ori-side-menu__section">
        <h2 class="ori-side-menu__section-title">{section.title}</h2>
        <ul class="ori-side-menu__list">
          {section.items.map((item) => (
            <li>
              <a
                class="ori-side-menu__link"
                href={item.href}
                aria-current={current === item.slug ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</aside>
