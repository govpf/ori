---
interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings?: TocItem[];
  title?: string;
}

const { headings = [], title = 'Sur cette page' } = Astro.props;

// On n'affiche que h2 et h3 pour rester lisible.
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  filtered.length > 0 && (
    <nav class="ori-toc" aria-label={title}>
      <p class="ori-toc__title">{title}</p>
      <ol class="ori-toc__list">
        {filtered.map((h) => (
          <li>
            <a
              class="ori-toc__link"
              href={`#${h.slug}`}
              data-ori-toc-link
              data-depth={h.depth}
              style={h.depth === 3 ? 'padding-left: 1.5rem;' : undefined}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}

<script>
  // Scroll-spy : marque le lien actif via aria-current="true".
  // IntersectionObserver sur les headings, puis on ajuste la classe du lien
  // correspondant. Pas de polling, pas de lib externe.
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-ori-toc-link]');
  if (links.length > 0) {
    const targets: HTMLElement[] = [];
    links.forEach((link) => {
      const id = link.getAttribute('href')?.slice(1);
      if (!id) return;
      const heading = document.getElementById(id);
      if (heading) targets.push(heading);
    });

    const setActive = (id: string) => {
      links.forEach((link) => {
        const slug = link.getAttribute('href')?.slice(1);
        if (slug === id) link.setAttribute('aria-current', 'true');
        else link.removeAttribute('aria-current');
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (visible) setActive(visible.target.id);
      },
      { rootMargin: '-20% 0px -70% 0px' },
    );

    targets.forEach((t) => observer.observe(t));
  }
</script>
