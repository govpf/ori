---
import { semanticGroups, type SemanticGroup } from '../../data/tokens';

interface Props {
  category: SemanticGroup['category'];
}

const { category } = Astro.props;
const group = semanticGroups.find((g) => g.category === category);
if (!group) throw new Error(`Unknown semantic group: ${category}`);
---

<section class="semantic-section">
  <header class="semantic-header">
    <h2 class="semantic-title">{group.category}</h2>
    <p class="semantic-description">{group.description}</p>
  </header>
  <div class="semantic-grid">
    {
      group.tokens.map((token) => (
        <article class="semantic-row">
          <div
            class="semantic-row__color"
            style={`background-color: var(${token.varName});`}
          />
          <div class="semantic-row__meta">
            <strong class="semantic-row__name">{token.name}</strong>
            {token.hint && <span class="semantic-row__hint">{token.hint}</span>}
            <div class="semantic-row__refs">
              <code>{token.varName}</code>
              <span class="semantic-row__arrow" aria-hidden="true">&rarr;</span>
              <code>{token.resolvesTo}</code>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .semantic-section {
    margin-block: 2rem;
  }
  .semantic-header {
    margin-bottom: 1rem;
  }
  .semantic-title {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .semantic-description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }
  .semantic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.625rem;
  }
  .semantic-row {
    display: flex;
    align-items: stretch;
    gap: 0.875rem;
    padding: 0.75rem;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    background-color: var(--color-surface-base);
  }
  .semantic-row__color {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: 0.375rem;
    box-shadow: inset 0 0 0 1px var(--color-border-subtle);
    align-self: center;
  }
  .semantic-row__meta {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .semantic-row__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .semantic-row__hint {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .semantic-row__refs {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.125rem;
    flex-wrap: wrap;
  }
  .semantic-row__refs code {
    font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    background: var(--color-surface-muted);
    padding: 0.0625rem 0.25rem;
    border-radius: 0.1875rem;
    border: 0;
  }
  .semantic-row__arrow {
    color: var(--color-text-muted);
    font-size: 0.75rem;
  }
</style>
