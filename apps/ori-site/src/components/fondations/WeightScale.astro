---
import { fontWeights } from '../../data/tokens';

const sample = "L'eau des lagons polynésiens";
---

<table class="weight-scale">
  <thead>
    <tr>
      <th>Token</th>
      <th>Valeur</th>
      <th>Échantillon</th>
      <th>Usage</th>
    </tr>
  </thead>
  <tbody>
    {
      fontWeights.map((w) => (
        <tr>
          <td><code>{w.name}</code></td>
          <td><code>{w.weight}</code></td>
          <td>
            <span style={`font-weight: ${w.weight}; font-size: 1.125rem;`}>{sample}</span>
          </td>
          <td>{w.usage}</td>
        </tr>
      ))
    }
  </tbody>
</table>

<style>
  .weight-scale {
    width: 100%;
    margin: 1rem 0 2rem;
    border-collapse: collapse;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--color-surface-base);
  }
  .weight-scale thead {
    background-color: var(--color-surface-muted);
  }
  .weight-scale th {
    padding: 0.625rem 0.875rem;
    text-align: start;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .weight-scale td {
    padding: 0.875rem;
    border-bottom: 1px solid var(--color-border-subtle);
    vertical-align: middle;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }
  .weight-scale td:nth-child(3) {
    color: var(--color-text-primary);
  }
  .weight-scale tr:last-child td {
    border-bottom: 0;
  }
  .weight-scale code {
    font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    background-color: var(--color-surface-muted);
    border: 1px solid var(--color-border-subtle);
    padding: 0.0625rem 0.375rem;
    border-radius: 0.1875rem;
    color: var(--color-text-primary);
  }
</style>
