---
import { palettes, type Palette } from '../../data/tokens';

interface Props {
  family: Palette['family'];
}

const { family } = Astro.props;
const palette = palettes.find((p) => p.family === family);
if (!palette) throw new Error(`Unknown palette family: ${family}`);
---

<section class="palette-section">
  <header class="palette-header">
    <h2 class="palette-title">{palette.family}</h2>
    <p class="palette-description">{palette.description}</p>
  </header>
  <div class="palette-grid">
    {
      palette.shades.map(({ shade, hex }) => (
        <article class="swatch">
          <div class="swatch__color" style={`background-color: ${hex};`} />
          <div class="swatch__meta">
            <strong class="swatch__name">
              {palette.family} <span class="swatch__shade">/ {shade}</span>
            </strong>
            <code class="swatch__hex">{hex.toUpperCase()}</code>
            <code class="swatch__var">--color-{palette.family}-{shade}</code>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .palette-section {
    margin-block: 2rem;
  }
  .palette-header {
    margin-bottom: 1rem;
  }
  .palette-title {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
    font-weight: 600;
    text-transform: capitalize;
    color: var(--color-text-primary);
  }
  .palette-description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }
  .palette-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }
  .swatch {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--color-surface-base);
    transition: border-color 150ms;
  }
  .swatch:hover {
    border-color: var(--color-border-default);
  }
  .swatch__color {
    height: 72px;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .swatch__meta {
    padding: 0.625rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .swatch__name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .swatch__shade {
    font-weight: 400;
    color: var(--color-text-muted);
  }
  .swatch__hex {
    font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: none;
    border: 0;
    padding: 0;
  }
  .swatch__var {
    font-family: ui-monospace, 'SF Mono', Menlo, Monaco, Consolas, monospace;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    background: none;
    border: 0;
    padding: 0;
  }
</style>
