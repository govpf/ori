{
  "name": "@govpf/ori-storybook-react",
  "version": "0.1.3",
  "private": true,
  "description": "Atelier de développement et documentation interactive Ori",
  "type": "module",
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build": "storybook build -o storybook-static",
    "test:a11y": "test-storybook --url http://127.0.0.1:6006",
    "test:a11y:ci": "concurrently -k -s first -n SB,A11Y \"http-server storybook-static -p 6006 -s\" \"wait-on tcp:6006 && test-storybook --url http://127.0.0.1:6006\""
  },
  "dependencies": {
    "@govpf/ori-react": "workspace:*",
    "@govpf/ori-tailwind-preset": "workspace:*",
    "@govpf/ori-tokens": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-themes": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/manager-api": "^8.6.18",
    "@storybook/react": "^8.4.7",
    "@storybook/theming": "^8.6.18",
    "@storybook/react-vite": "^8.4.7",
    "@storybook/test": "^8.6.18",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.11",
    "remark-gfm": "^4.0.0",
    "storybook": "^8.4.7",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "@storybook/test-runner": "^0.19.1",
    "axe-playwright": "^2.1.0",
    "concurrently": "^9.1.0",
    "http-server": "^14.1.1",
    "playwright": "^1.59.1",
    "wait-on": "^8.0.1"
  }
}
